# 环境变量配置
# 复制此文件为 .env 并填写实际值

# 数据库配置（Docker Compose 内部使用）
DB_HOST=postgres
DB_PORT=5432
DB_NAME=iquant
DB_USER=iquant
DB_PASSWORD=iquant123

# Redis 配置
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# FastAPI 配置
FASTAPI_ENV=production
FASTAPI_DEBUG=false

# Grafana 配置（可选）
GRAFANA_ADMIN_PASSWORD=admin

# 可选：外部 API 密钥
TUSHARE_TOKEN=your_tushare_token
